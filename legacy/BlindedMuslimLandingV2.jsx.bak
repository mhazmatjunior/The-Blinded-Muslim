            {shifts.map(([_, to]) => (
              <div key={to} style={{ padding: "1.25rem 0 1.25rem 2rem", borderBottom: "1px solid rgba(184,136,60,0.08)" }}>
                <span style={{ color: "var(--parchment)", fontSize: "0.97rem", fontWeight: 500 }}>{to}</span>
              </div>
            ))}
