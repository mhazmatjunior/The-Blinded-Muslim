        </div>

        <p className="f-display reveal" style={{ textAlign: "center", color: "var(--gold-light)", fontStyle: "italic", fontSize: "1.1rem", marginTop: "3rem" }}>
          This is not just learning — it is realignment of thought, belief, and direction.
        </p>
      </div>
    </section>
