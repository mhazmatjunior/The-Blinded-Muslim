                <p className="f-display" style={{ color: "var(--gold)", fontStyle: "italic", fontSize: "1rem", borderTop: "1px solid var(--border)", paddingTop: "1.2rem" }}>
                  → {mod.close}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  );
}

